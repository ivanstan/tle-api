{
  "openapi": "3.1.1",
  "info": {
    "title": "TLE API",
    "version": "2.0.0",
    "description": "Public API for querying Two-Line Element (TLE) sets by satellite ID or via a searchable collection endpoint.",
    "contact": {
      "name": "Ivan Stanojevic",
      "email": "istanojevic@itekako.com",
      "url": "https://tle.ivanstanojevic.me"
    }
  },
  "servers": [
    {
      "url": "https://tle.ivanstanojevic.me"
    }
  ],
  "tags": [
    {
      "name": "TLE",
      "description": "Endpoints for listing and retrieving TLE records."
    }
  ],
  "paths": {
    "/api/tle": {
      "get": {
        "tags": ["TLE"],
        "summary": "Collection",
        "operationId": "collection",
        "description": "Return collection of TleModels depending on requested parameters",
        "parameters": [
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/sort" },
          { "$ref": "#/components/parameters/sortDirection" },
          { "$ref": "#/components/parameters/pageNumber" },
          { "$ref": "#/components/parameters/pageSize" },
          { "$ref": "#/components/parameters/eccentricityGte" },
          { "$ref": "#/components/parameters/eccentricityLte" },
          { "$ref": "#/components/parameters/inclinationLt" },
          { "$ref": "#/components/parameters/inclinationGt" },
          { "$ref": "#/components/parameters/periodLt" },
          { "$ref": "#/components/parameters/periodGt" }
        ],
        "responses": {
          "200": {
            "description": "Resource found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TleCollection" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exception" },
                "example": { "response": { "message": "Server has encountered an internal error" } }
              }
            }
          }
        }
      }
    },
    "/api/tle/{id}": {
      "get": {
        "tags": ["TLE"],
        "summary": "Record",
        "operationId": "record",
        "description": "Return single TleModel for requested satellite id",
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": {
            "description": "Resource found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TleModel" }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exception" },
                "example": { "response": { "message": "Resource not found" } }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exception" },
                "example": { "response": { "message": "Server has encountered an internal error" } }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TleCollection": {
        "type": "object",
        "properties": {
          "@context": { "type": "string", "format": "uri" },
          "@id": { "type": "string", "format": "uri" },
          "@type": { "type": "string" },
          "totalItems": { "type": "integer" },
          "member": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TleModel" }
          },
          "parameters": { "type": "object" },
          "view": { "$ref": "#/components/schemas/Pagination" }
        },
        "required": ["totalItems", "member"]
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "@id": { "type": "string", "format": "uri" },
          "@type": { "type": "string" },
          "first": { "type": "string", "format": "uri-reference" },
          "previous": { "type": "string", "format": "uri-reference" },
          "next": { "type": "string", "format": "uri-reference" },
          "last": { "type": "string", "format": "uri-reference" }
        }
      },
      "Exception": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            },
            "required": ["message"]
          }
        },
        "required": ["response"]
      },
      "TleModel": {
        "type": "object",
        "properties": {
          "@context": { "type": "string", "format": "uri" },
          "@id": { "type": "string", "format": "uri" },
          "@type": { "type": "string" },
          "satelliteId": { "type": "integer" },
          "name": { "type": "string" },
          "date": { "type": "string", "format": "date-time" },
          "line1": { "type": "string" },
          "line2": { "type": "string" }
        },
        "required": ["satelliteId", "name", "date", "line1", "line2"]
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "description": "Satellite id",
        "required": true,
        "schema": { "type": "integer", "example": 43638 }
      },
      "search": {
        "name": "search",
        "in": "query",
        "description": "Search string",
        "schema": { "type": "string", "default": "*" }
      },
      "sort": {
        "name": "sort",
        "in": "query",
        "description": "Sort by",
        "schema": {
          "type": "string",
          "default": "name",
          "enum": ["id", "name", "popularity", "inclination", "eccentricity", "period"]
        }
      },
      "sortDirection": {
        "name": "sort-dir",
        "in": "query",
        "description": "Sort direction",
        "schema": { "type": "string", "default": "asc", "enum": ["asc", "desc"] }
      },
      "pageNumber": {
        "name": "page",
        "in": "query",
        "description": "Page number",
        "schema": { "type": "integer", "default": 1, "minimum": 1 }
      },
      "pageSize": {
        "name": "page-size",
        "in": "query",
        "description": "Number of collection member per page",
        "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 100 }
      },

      "eccentricityGte": {
        "name": "eccentricity[gte]",
        "in": "query",
        "description": "Filter records with orbital eccentricity greater then or equal to the provided value",
        "required": false,
        "schema": { "type": "number", "minimum": 0, "maximum": 1 },
        "example": 0.1
      },
      "eccentricityLte": {
        "name": "eccentricity[lte]",
        "in": "query",
        "description": "Filter records with orbital eccentricity less then or equal to the provided value",
        "required": false,
        "schema": { "type": "number", "minimum": 0, "maximum": 1 },
        "example": 0.9
      },
      "inclinationLt": {
        "name": "inclination[lt]",
        "in": "query",
        "description": "Filter records with posigrade orbital inclination",
        "required": false,
        "schema": { "type": "number", "minimum": 0, "maximum": 180 },
        "example": 90
      },
      "inclinationGt": {
        "name": "inclination[gt]",
        "in": "query",
        "description": "Filter records with retrograde orbital inclination",
        "required": false,
        "schema": { "type": "number", "minimum": 0, "maximum": 180 },
        "example": 90
      },
      "periodLt": {
        "name": "period[lt]",
        "in": "query",
        "description": "Filter records with orbital period less than specified",
        "required": false,
        "schema": { "type": "number", "minimum": 0 },
        "example": 255
      },
      "periodGt": {
        "name": "period[gt]",
        "in": "query",
        "description": "Filter records with orbital period greater than specified",
        "required": false,
        "schema": { "type": "number", "minimum": 0 },
        "example": 255
      }
    }
  }
}
